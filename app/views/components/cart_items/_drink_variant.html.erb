<% drink_variant = cart_item.cart_itemable %>

<%= turbo_frame_tag dom_id(cart_item) do %>
    <div class="flex items-center justify-between space-x-3 p-3">
        <div class="grow flex items-center space-x-2">
            <div class="w-20 flex flex-col items-center">
                <%= image_tag drink_variant.detail_image.variant(:thumb),
                    class: "object-contain" %>
            </div>
            <div class="flex grow flex-col">
                <%= tag.span drink_variant.drink.name %>
                <div class="flex space-x-2">
                    <%= tag.span drink_variant.name, class: "text-xs text-green-500" %>
                </div>
                <div class="flex mt-1 items-center justify-between">
                    <%= component "cart_items/shared/controls",
                        cart_itemable_type: cart_item.cart_itemable_type,
                        cart_itemable_id: cart_item.cart_itemable_id,
                        quantity: cart_item.quantity %>
                    <span class="font-semibold"><%= cart_item.total_price %> UAH</span>
                </div>
            </div>
        </div>
    </div>
<% end %>