<%= turbo_stream.replace k(@cart_itemable).dom_id do %>
     <%= render CartButtonComponent.new(
          cart_itemable: @cart_itemable,
          quantity: @cart_item.quantity
     ) %>
<% end %>

<%= turbo_stream.replace "header_cart" do %>
     <%= render HeaderCartComponent.new(cart: @cart_item.cart) %>
<% end %>

<%= turbo_stream.replace dom_id(@cart_item.cart) do %>
     <%= component "cart_info", cart: @cart_item.cart %>
<% end %>

<% if @cart_item.quantity == 0 %>
     <%= turbo_stream.remove dom_id(@cart_item) %>
<% else %>
     <%= turbo_stream.replace dom_id(@cart_item) do %>
          <%= component @cart_item.partial_path, cart_item: @cart_item %>
     <% end %>
<% end %>