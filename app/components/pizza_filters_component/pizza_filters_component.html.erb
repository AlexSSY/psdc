<%= form_tag root_path,
    method: :get,
    class: "flex items-center space-x-4",
    data: {
        controller: "pizza-filters",
        pizza_filters_target: "form"
    } do |f| %> 
    <select class="py-2 px-4 border border-gray-300 rounded-md flex items-center" name="sort_by" data-action="pizza-filters#submitForm">
        <%= options_for_select(
            sort_by_select_items,
            pizza_filters.sort_by) %>
    </select>
    <% ingredients.each_pair do |category, items| %>
        <%= render DropdownListComponent.new do |dropdown| %>
            <% dropdown.with_button do %>
                <div class="py-2 px-4 border border-gray-300 rounded-md flex items-center">
                    <span class="mr-2"><%= selected_ingredients(category).size > 0 ? "#{category} (#{selected_ingredients(category).size})" : category %></span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </div>
            <% end %>
            <% items.each_pair do |key, value| %>
                <% dropdown.with_item do %>
                    <label class="flex items-center space-x-2">
                        <input type="checkbox" name="ingredients[]" value="<%= value %>" <%= "checked" if pizza_filters.ingredients.include?(value.to_s) %>>
                        <span><%= key %></span>
                    </label>
                <% end %>
            <% end %>
        <% end %>
    <% end %>
    <input type="submit" value="Apply" class="px-4 py-2 bg-blue-500 text-white rounded-md cursor-pointer">
<% end %>